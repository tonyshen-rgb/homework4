<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Places</h1>
  <a href="/places/new" class="btn btn-primary">New Place</a>
</div>

<ul class="list-group">
  <% for place in @places %>
    <li class="list-group-item">
      <a href="/places/<%= place["id"] %>"><%= place["name"] %></a>
    </li>
  <% end %>
</ul>