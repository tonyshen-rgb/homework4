<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= @place["name"] %></h1>

  <% if current_user != nil %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
  <% end %>
</div>

<h2 class="mb-3">My Entries</h2>

<% if @entries.any? %>
  <div class="row">
    <% for entry in @entries %>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <% if entry.image.attached? %>
            <%= image_tag entry.image, class: "card-img-top" %>
          <% end %>

          <div class="card-body">
            <h5 class="card-title"><%= entry["title"] %></h5>
            <h6 class="card-subtitle mb-2 text-muted"><%= entry["occurred_on"] %></h6>
            <p class="card-text"><%= entry["description"] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <% if current_user == nil %>
    <p>Please <a href="/login">log in</a> to see your entries.</p>
  <% else %>
    <p>No entries yet for this place.</p>
  <% end %>
<% end %>

<a href="/places" class="btn btn-secondary">Back to All Places</a>